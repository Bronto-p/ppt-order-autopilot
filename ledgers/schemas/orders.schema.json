{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Orders Ledger Record",
  "type": "object",
  "required": [
    "event",
    "order_id",
    "title",
    "order_path",
    "timestamp"
  ],
  "properties": {
    "event": {
      "const": "order_created"
    },
    "order_id": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}_\\d{3}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "contact": {
      "type": [
        "string",
        "null"
      ]
    },
    "order_path": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}

