{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Approval Ledger Record",
  "type": "object",
  "required": [
    "approval_id",
    "action_type",
    "status",
    "draft_sha256",
    "created_at"
  ],
  "properties": {
    "approval_id": {
      "type": "string",
      "pattern": "^appr_[a-zA-Z0-9_-]+$"
    },
    "order_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "action_type": {
      "type": "string",
      "minLength": 1
    },
    "contact_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "draft_sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "status": {
      "enum": [
        "pending",
        "approved",
        "rejected",
        "expired"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "approved_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  },
  "additionalProperties": false
}

