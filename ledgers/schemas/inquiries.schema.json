{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Inquiry Ledger Record",
  "type": "object",
  "required": ["event", "inquiry_id", "source_type", "timestamp"],
  "properties": {
    "event": {"enum": ["staged", "promotion_intent", "inquiry_promoted", "blocked"]},
    "inquiry_id": {"type": "string", "minLength": 1},
    "source_type": {"enum": ["wecom", "codex_attachment"]},
    "source_digest": {"type": ["string", "null"], "pattern": "^sha256:[a-f0-9]{64}$"},
    "source_message_id": {"type": ["string", "null"]},
    "source_prompt_path": {"type": ["string", "null"]},
    "source_prompt_sha256": {"type": ["string", "null"], "pattern": "^sha256:[a-f0-9]{64}$"},
    "order_id": {"type": ["string", "null"]},
    "order_path": {"type": ["string", "null"]},
    "timestamp": {"type": "string", "format": "date-time"},
    "details": {"type": ["object", "null"]}
  },
  "allOf": [
    {
      "if": {"properties": {"source_type": {"const": "codex_attachment"}}},
      "then": {
        "required": ["source_digest", "source_message_id", "source_prompt_path", "source_prompt_sha256"],
        "properties": {
          "source_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
          "source_message_id": {"type": "string", "minLength": 1},
          "source_prompt_path": {"type": "string", "minLength": 1},
          "source_prompt_sha256": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}
        }
      }
    }
  ],
  "additionalProperties": false
}
