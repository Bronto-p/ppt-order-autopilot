{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Skill Result",
  "type": "object",
  "required": [
    "status",
    "confidence",
    "evidence_files",
    "next_action",
    "requires_owner_approval"
  ],
  "properties": {
    "status": {
      "enum": [
        "success",
        "blocked",
        "failed"
      ]
    },
    "confidence": {
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "evidence_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_action": {
      "type": [
        "string",
        "null"
      ]
    },
    "requires_owner_approval": {
      "type": "boolean"
    },
    "blocked_reason": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": true
}
