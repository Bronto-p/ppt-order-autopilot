{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Payment Status",
  "type": "object",
  "required": [
    "status"
  ],
  "properties": {
    "status": {
      "enum": [
        "unknown",
        "pending",
        "partial",
        "paid",
        "waived"
      ]
    },
    "amount": {
      "type": [
        "number",
        "null"
      ]
    },
    "currency": {
      "type": [
        "string",
        "null"
      ]
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": false
}

