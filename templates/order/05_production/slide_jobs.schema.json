{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Bundled Slide Jobs",
  "type": "object",
  "required": [
    "contract_path",
    "jobs"
  ],
  "properties": {
    "contract_path": {
      "const": "03_requirements/production_contract.json"
    },
    "jobs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "slide_no",
          "bundle_dir",
          "job_file",
          "prompt_file",
          "input_images_dir",
          "render_result_file",
          "output_image"
        ],
        "properties": {
          "slide_no": {
            "type": "integer",
            "minimum": 1
          },
          "bundle_dir": {
            "type": "string",
            "pattern": "^05_production/slide_jobs/slide_\\d{2,}$"
          },
          "job_file": {
            "type": "string",
            "pattern": "^05_production/slide_jobs/slide_\\d{2,}/job\\.json$"
          },
          "prompt_file": {
            "type": "string",
            "pattern": "^05_production/slide_jobs/slide_\\d{2,}/prompt\\.md$"
          },
          "input_images_dir": {
            "type": "string",
            "pattern": "^05_production/slide_jobs/slide_\\d{2,}/input_images$"
          },
          "render_result_file": {
            "type": "string",
            "pattern": "^05_production/slide_jobs/slide_\\d{2,}/render_result\\.json$"
          },
          "output_image": {
            "type": "string",
            "pattern": "^05_production/origin_image/slide_\\d{2,}\\.png$"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

