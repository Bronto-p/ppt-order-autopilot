{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Slide Render Result",
  "type": "object",
  "required": [
    "job_id",
    "attempt",
    "slide_no",
    "output_mode",
    "status",
    "output_image",
    "editable_artifacts",
    "input_images_seen",
    "asset_fidelity",
    "style_match",
    "text_readability",
    "blockers"
  ],
  "properties": {
    "job_id": {
      "type": "string",
      "minLength": 1
    },
    "attempt": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3
    },
    "slide_no": {
      "type": "integer",
      "minimum": 1
    },
    "output_mode": {
      "enum": [
        "image_first",
        "hybrid",
        "template_native",
        "editable_reconstruction"
      ]
    },
    "status": {
      "enum": [
        "success",
        "blocked",
        "failed"
      ]
    },
    "output_image": {
      "type": [
        "string",
        "null"
      ]
    },
    "editable_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "sha256", "role"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
          "role": {"enum": ["native_slide", "editable_layer_spec", "chart_data", "table_data", "speaker_notes"]}
        },
        "additionalProperties": false
      }
    },
    "input_images_seen": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "asset_fidelity": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "asset",
          "status"
        ],
        "properties": {
          "asset": {
            "type": "string"
          },
          "status": {
            "enum": [
              "pass",
              "fail",
              "not_applicable"
            ]
          },
          "notes": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "style_match": {
      "enum": [
        "pass",
        "medium",
        "fail"
      ]
    },
    "text_readability": {
      "enum": [
        "pass",
        "fail"
      ]
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
