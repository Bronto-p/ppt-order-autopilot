{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Production Blueprint",
  "type": "object",
  "required": [
    "contract_path",
    "style_kit_path",
    "slide_jobs_path",
    "slide_run_state_path",
    "assembly_policy"
  ],
  "properties": {
    "contract_path": {
      "const": "03_requirements/production_contract.json"
    },
    "style_kit_path": {
      "const": "04_sample/style_kit"
    },
    "slide_jobs_path": {
      "const": "05_production/slide_jobs/slide_jobs.json"
    },
    "slide_run_state_path": {
      "const": "05_production/slide_run_state.json"
    },
    "assembly_policy": {
      "type": "object",
      "required": [
        "supported_output_modes",
        "preserve_editable_artifacts"
      ],
      "properties": {
        "supported_output_modes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "image_first",
              "hybrid",
              "template_native",
              "editable_reconstruction"
            ]
          }
        },
        "preserve_editable_artifacts": {
          "const": true
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
