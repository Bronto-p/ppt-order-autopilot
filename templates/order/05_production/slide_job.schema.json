{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Slide Job",
  "type": "object",
  "required": [
    "slide_id",
    "slide_no",
    "title",
    "page_type",
    "deck_context",
    "local_context",
    "exact_content",
    "input_images",
    "visual_constraints",
    "backend",
    "worker_policy",
    "qa_requirements"
  ],
  "properties": {
    "slide_id": {
      "type": "string",
      "pattern": "^slide_\\d{2,}$"
    },
    "slide_no": {
      "type": "integer",
      "minimum": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "page_type": {
      "type": "string",
      "minLength": 1
    },
    "deck_context": {
      "type": "object",
      "required": [
        "deck_theme",
        "confirmed_style",
        "canonical_terms"
      ],
      "properties": {
        "deck_theme": {
          "type": "string",
          "minLength": 1
        },
        "confirmed_style": {
          "type": "string",
          "minLength": 1
        },
        "canonical_terms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "local_context": {
      "type": "object",
      "minProperties": 1
    },
    "exact_content": {
      "type": "object",
      "minProperties": 1
    },
    "input_images": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "path",
          "role",
          "required"
        ],
        "properties": {
          "asset_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean"
          },
          "fidelity_rule": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "visual_constraints": {
      "type": "object",
      "minProperties": 1
    },
    "backend": {
      "type": "object",
      "required": [
        "selected_backend",
        "requires_image_inputs"
      ],
      "properties": {
        "selected_backend": {
          "type": "string",
          "minLength": 1
        },
        "requires_image_inputs": {
          "const": true
        }
      },
      "additionalProperties": false
    },
    "worker_policy": {
      "type": "object",
      "required": [
        "reasoning_level",
        "must_return_blocker_if_image_not_visible",
        "must_not_use_text_only_fallback"
      ],
      "properties": {
        "reasoning_level": {
          "enum": [
            "medium",
            "high"
          ]
        },
        "must_return_blocker_if_image_not_visible": {
          "const": true
        },
        "must_not_use_text_only_fallback": {
          "const": true
        }
      },
      "additionalProperties": false
    },
    "qa_requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}

