{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Bundled Slide Job",
  "type": "object",
  "required": [
    "job_id",
    "attempt",
    "max_attempts",
    "slide_no",
    "page_type",
    "title",
    "output_mode",
    "deck_context",
    "local_context",
    "exact_content",
    "input_images",
    "visual_constraints",
    "backend",
    "qa_requirements",
    "worker_policy"
  ],
  "properties": {
    "job_id": {
      "type": "string",
      "minLength": 1
    },
    "attempt": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3
    },
    "max_attempts": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3
    },
    "repair_of": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1
    },
    "slide_no": {
      "type": "integer",
      "minimum": 1
    },
    "page_type": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "output_mode": {
      "enum": [
        "image_first",
        "hybrid",
        "template_native",
        "editable_reconstruction"
      ]
    },
    "deck_context": {
      "type": "object",
      "required": [
        "deck_title",
        "goal",
        "audience",
        "story_summary",
        "total_slides",
        "language"
      ],
      "properties": {
        "deck_title": {"type": "string", "minLength": 1},
        "goal": {"type": "string", "minLength": 1},
        "audience": {"type": "string", "minLength": 1},
        "story_summary": {"type": "string", "minLength": 1},
        "total_slides": {"type": "integer", "minimum": 1},
        "language": {"type": "string", "minLength": 2}
      },
      "additionalProperties": false
    },
    "local_context": {
      "type": "object",
      "required": [
        "section",
        "slide_purpose",
        "previous_slide_summary",
        "next_slide_summary"
      ],
      "properties": {
        "section": {"type": "string", "minLength": 1},
        "slide_purpose": {"type": "string", "minLength": 1},
        "previous_slide_summary": {"type": ["string", "null"]},
        "next_slide_summary": {"type": ["string", "null"]}
      },
      "additionalProperties": false
    },
    "exact_content": {
      "type": "object",
      "minProperties": 1
    },
    "input_images": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "image_id",
          "bundle_path",
          "role",
          "required",
          "fidelity_rule"
        ],
        "properties": {
          "image_id": {
            "type": "string",
            "minLength": 1
          },
          "source_asset_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "bundle_path": {
            "type": "string",
            "pattern": "^input_images/.+"
          },
          "role": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean"
          },
          "fidelity_rule": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": [
              "string",
              "null"
            ]
          },
          "if_missing": {
            "enum": [
              "block",
              "omit_if_optional"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "visual_constraints": {
      "type": "object",
      "required": [
        "must_match_style_anchor",
        "use_navigation_bar",
        "locked_chrome"
      ],
      "properties": {
        "must_match_style_anchor": {
          "type": "boolean"
        },
        "use_navigation_bar": {
          "type": "boolean"
        },
        "active_navigation_section": {
          "type": [
            "string",
            "null"
          ]
        },
        "locked_elements": {
          "type": [
            "string",
            "null"
          ]
        },
        "locked_chrome": {
          "type": "object",
          "required": [
            "mode",
            "variant_id",
            "active_navigation_section",
            "page_number_text",
            "style_variant_path",
            "style_variant_sha256",
            "overlay_bundle_path",
            "overlay_sha256",
            "content_safe_box"
          ],
          "properties": {
            "mode": {
              "enum": [
                "none",
                "post_generation_composite"
              ]
            },
            "variant_id": {
              "type": [
                "string",
                "null"
              ],
              "minLength": 1
            },
            "active_navigation_section": {
              "type": [
                "string",
                "null"
              ],
              "minLength": 1
            },
            "page_number_text": {
              "type": ["string", "null"]
            },
            "style_variant_path": {
              "type": ["string", "null"],
              "pattern": "^04_sample/style_kit/.+"
            },
            "style_variant_sha256": {
              "type": ["string", "null"],
              "pattern": "^sha256:[a-f0-9]{64}$"
            },
            "overlay_bundle_path": {
              "type": [
                "string",
                "null"
              ],
              "pattern": "^input_images/.+"
            },
            "overlay_sha256": {
              "type": [
                "string",
                "null"
              ],
              "pattern": "^sha256:[a-f0-9]{64}$"
            },
            "content_safe_box": {
              "type": [
                "object",
                "null"
              ],
              "required": [
                "x",
                "y",
                "w",
                "h"
              ],
              "properties": {
                "x": {"type": "integer", "minimum": 0},
                "y": {"type": "integer", "minimum": 0},
                "w": {"type": "integer", "minimum": 1},
                "h": {"type": "integer", "minimum": 1}
              },
              "additionalProperties": false
            }
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "mode": {
                    "const": "post_generation_composite"
                  }
                }
              },
              "then": {
                "properties": {
                  "overlay_bundle_path": {
                    "type": "string"
                  },
                  "variant_id": {
                    "type": "string"
                  },
                  "style_variant_path": {
                    "type": "string"
                  },
                  "style_variant_sha256": {
                    "type": "string"
                  },
                  "overlay_sha256": {
                    "type": "string"
                  },
                  "content_safe_box": {
                    "type": "object"
                  }
                }
              },
              "else": {
                "properties": {
                  "overlay_bundle_path": {
                    "type": "null"
                  },
                  "variant_id": {
                    "type": "null"
                  },
                  "active_navigation_section": {
                    "type": "null"
                  },
                  "page_number_text": {
                    "type": "null"
                  },
                  "style_variant_path": {
                    "type": "null"
                  },
                  "style_variant_sha256": {
                    "type": "null"
                  },
                  "overlay_sha256": {
                    "type": "null"
                  },
                  "content_safe_box": {
                    "type": "null"
                  }
                }
              }
            }
          ],
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    },
    "backend": {
      "type": "object",
      "required": [
        "selected_backend",
        "mode",
        "requires_image_inputs"
      ],
      "properties": {
        "selected_backend": {"type": "string", "minLength": 1},
        "mode": {
          "enum": [
            "reference_guided_generation",
            "image_edit",
            "hybrid_assets",
            "template_native",
            "editable_reconstruction"
          ]
        },
        "requires_image_inputs": {"const": true}
      },
      "additionalProperties": false
    },
    "qa_requirements": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "exact_content",
          "text_readability",
          "asset_fidelity",
          "style_match",
          "navigation",
          "canvas",
          "source_structure"
        ]
      }
    },
    "worker_policy": {
      "type": "object",
      "required": [
        "reasoning_level",
        "one_slide_only",
        "uses_image_generation",
        "image_generation_only",
        "must_generate_complete_slide",
        "must_render_all_visible_content",
        "forbid_background_only",
        "must_not_use_text_only_fallback",
        "if_required_image_missing"
      ],
      "properties": {
        "reasoning_level": {
          "enum": [
            "medium",
            "high"
          ]
        },
        "one_slide_only": {
          "const": true
        },
        "uses_image_generation": {
          "type": "boolean"
        },
        "image_generation_only": {
          "type": "boolean"
        },
        "must_generate_complete_slide": {
          "type": "boolean"
        },
        "must_render_all_visible_content": {
          "type": "boolean"
        },
        "forbid_background_only": {
          "const": true
        },
        "must_not_use_text_only_fallback": {
          "const": true
        },
        "if_required_image_missing": {
          "const": "block"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
