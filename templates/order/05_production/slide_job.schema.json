{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Bundled Slide Job",
  "type": "object",
  "required": [
    "slide_no",
    "page_type",
    "title",
    "exact_content",
    "input_images",
    "visual_constraints",
    "worker_policy"
  ],
  "properties": {
    "slide_no": {
      "type": "integer",
      "minimum": 1
    },
    "page_type": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "exact_content": {
      "type": "object",
      "minProperties": 1
    },
    "input_images": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "image_id",
          "bundle_path",
          "role",
          "required",
          "fidelity_rule"
        ],
        "properties": {
          "image_id": {
            "type": "string",
            "minLength": 1
          },
          "source_asset_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "bundle_path": {
            "type": "string",
            "pattern": "^input_images/.+"
          },
          "role": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean"
          },
          "fidelity_rule": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": [
              "string",
              "null"
            ]
          },
          "if_missing": {
            "enum": [
              "block",
              "omit_if_optional"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "visual_constraints": {
      "type": "object",
      "required": [
        "must_match_style_anchor",
        "use_navigation_bar"
      ],
      "properties": {
        "must_match_style_anchor": {
          "type": "boolean"
        },
        "use_navigation_bar": {
          "type": "boolean"
        },
        "active_navigation_section": {
          "type": [
            "string",
            "null"
          ]
        },
        "locked_elements": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "worker_policy": {
      "type": "object",
      "required": [
        "reasoning_level",
        "image_generation_only",
        "must_not_use_text_only_fallback",
        "if_required_image_missing"
      ],
      "properties": {
        "reasoning_level": {
          "enum": [
            "medium",
            "high"
          ]
        },
        "image_generation_only": {
          "const": true
        },
        "must_not_use_text_only_fallback": {
          "const": true
        },
        "if_required_image_missing": {
          "const": "block"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

