{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sample Contract",
  "type": "object",
  "required": [
    "sample_page_count",
    "sample_slide_no",
    "sample_goal",
    "use_real_content",
    "output_mode",
    "generation_scope",
    "reference_files",
    "approval_id",
    "backend"
  ],
  "properties": {
    "sample_page_count": {
      "const": 1
    },
    "sample_slide_no": {
      "type": "integer",
      "minimum": 1
    },
    "sample_goal": {
      "enum": [
        "style_check",
        "content_check",
        "both"
      ]
    },
    "use_real_content": {
      "const": true
    },
    "output_mode": {
      "enum": [
        "image_first",
        "hybrid",
        "template_native",
        "editable_reconstruction"
      ]
    },
    "generation_scope": {
      "const": "complete_slide"
    },
    "reference_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "approval_id": {
      "type": "string",
      "minLength": 1
    },
    "backend": {
      "type": "object",
      "required": [
        "selected_backend",
        "requires_image_inputs",
        "uses_image_generation",
        "image_generation_only"
      ],
      "properties": {
        "selected_backend": {
          "type": "string",
          "minLength": 1
        },
        "requires_image_inputs": {
          "type": "boolean"
        },
        "uses_image_generation": {
          "const": true
        },
        "image_generation_only": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {"properties": {"output_mode": {"const": "image_first"}}},
      "then": {"properties": {"backend": {"properties": {"image_generation_only": {"const": true}}}}}
    }
  ],
  "additionalProperties": false
}
