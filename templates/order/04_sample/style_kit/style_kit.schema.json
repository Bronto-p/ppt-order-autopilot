{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Style Kit",
  "type": "object",
  "required": [
    "source",
    "approved_sample_paths",
    "style_anchor",
    "template_master",
    "page_family_refs",
    "locked_elements",
    "must_match"
  ],
  "properties": {
    "source": {
      "type": "object",
      "required": [
        "source_type",
        "source_paths"
      ],
      "properties": {
        "source_type": {
          "enum": [
            "approved_sample",
            "customer_template",
            "source_deck",
            "approved_style_brief"
          ]
        },
        "source_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "approval_id": {
          "type": "string",
          "minLength": 1
        },
        "customer_decision_path": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "approved_sample_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "style_anchor": {
      "const": "04_sample/style_kit/style_anchor.png"
    },
    "template_master": {
      "const": "04_sample/style_kit/template_master.png"
    },
    "navigation_bar": {
      "type": [
        "string",
        "null"
      ]
    },
    "page_family_refs": {
      "type": "object",
      "required": [
        "cover",
        "content"
      ],
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "locked_elements": {
      "const": "04_sample/style_kit/locked_elements.json"
    },
    "must_match": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "color palette",
          "background treatment",
          "title hierarchy",
          "card radius",
          "spacing density",
          "logo position",
          "navigation geometry"
        ]
      },
      "uniqueItems": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "source": {
            "properties": {
              "source_type": {
                "const": "approved_sample"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "source": {
            "required": [
              "customer_decision_path"
            ]
          },
          "approved_sample_paths": {
            "minItems": 1
          }
        }
      },
      "else": {
        "properties": {
          "source": {
            "required": [
              "approval_id"
            ]
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
