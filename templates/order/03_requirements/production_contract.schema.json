{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PPT Production Contract",
  "type": "object",
  "required": [
    "deck",
    "production_method",
    "style_system",
    "asset_registry",
    "slides",
    "coverage_matrix",
    "approval"
  ],
  "properties": {
    "deck": {
      "type": "object",
      "required": [
        "deck_title",
        "page_count",
        "aspect_ratio",
        "deliverables",
        "language"
      ],
      "properties": {
        "deck_title": {
          "type": "string",
          "minLength": 1
        },
        "page_count": {
          "type": "integer",
          "minimum": 1
        },
        "aspect_ratio": {
          "enum": [
            "16:9",
            "4:3",
            "custom"
          ]
        },
        "deliverables": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "pptx",
              "pdf"
            ]
          },
          "uniqueItems": true
        },
        "language": {
          "type": "string",
          "minLength": 2
        },
        "requirements_source": {
          "type": "string",
          "default": "03_requirements/requirements.json"
        }
      },
      "additionalProperties": false
    },
    "production_method": {
      "type": "object",
      "required": [
        "method",
        "backend",
        "same_backend_as_sample",
        "parent_may_generate_slides",
        "subagents_required",
        "default_worker_reasoning_level",
        "forbidden_methods"
      ],
      "properties": {
        "method": {
          "const": "image_model_full_slide_only"
        },
        "backend": {
          "type": "string",
          "minLength": 1
        },
        "same_backend_as_sample": {
          "type": "boolean"
        },
        "parent_may_generate_slides": {
          "const": false
        },
        "subagents_required": {
          "const": true
        },
        "default_worker_reasoning_level": {
          "enum": [
            "medium",
            "high"
          ]
        },
        "forbidden_methods": {
          "type": "array",
          "items": {
            "enum": [
              "html_css_render",
              "svg_render",
              "pillow_slide",
              "manual_overlay",
              "python_pptx_native_layout"
            ]
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "style_system": {
      "type": "object",
      "required": [
        "style_anchor_paths",
        "template_master_path",
        "style_spec_path",
        "locked_elements_path",
        "page_family_refs"
      ],
      "properties": {
        "style_anchor_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "template_master_path": {
          "type": "string",
          "minLength": 1
        },
        "navigation_bar_reference_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "page_family_refs": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "style_spec_path": {
          "type": "string",
          "minLength": 1
        },
        "locked_elements_path": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "asset_registry": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/asset"
      }
    },
    "asset_allowlist": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "forbidden_assets": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/slide"
      }
    },
    "coverage_matrix": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/coverage"
      }
    },
    "approval": {
      "type": "object",
      "required": [
        "approval_id",
        "approved_by"
      ],
      "properties": {
        "approval_id": {
          "type": "string",
          "minLength": 1
        },
        "approved_by": {
          "type": "string",
          "minLength": 1
        },
        "approved_at": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "asset": {
      "type": "object",
      "required": [
        "asset_id",
        "path",
        "type",
        "allowed_use",
        "fidelity_rule"
      ],
      "properties": {
        "asset_id": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "enum": [
            "logo",
            "client_photo",
            "chart",
            "screenshot",
            "certificate",
            "source_slide_render",
            "extracted_media",
            "style_reference",
            "template_reference",
            "whole_slide_reference",
            "decorative_template_asset",
            "other"
          ]
        },
        "source_message_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "sha256": {
          "type": [
            "string",
            "null"
          ]
        },
        "allowed_use": {
          "type": "string",
          "minLength": 1
        },
        "fidelity_rule": {
          "$ref": "#/$defs/fidelity_rule"
        }
      },
      "additionalProperties": false
    },
    "slide": {
      "type": "object",
      "required": [
        "slide_no",
        "title",
        "page_type",
        "section",
        "exact_content",
        "content_evidence",
        "input_images",
        "layout_constraints",
        "must_preserve",
        "forbidden_changes",
        "worker",
        "qa_requirements"
      ],
      "properties": {
        "slide_no": {
          "type": "integer",
          "minimum": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "page_type": {
          "enum": [
            "cover",
            "section",
            "content",
            "data",
            "image_heavy",
            "timeline",
            "process",
            "closing",
            "custom"
          ]
        },
        "section": {
          "type": "string",
          "minLength": 1
        },
        "exact_content": {
          "type": "object",
          "minProperties": 1
        },
        "content_evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object"
          }
        },
        "input_images": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/input_image"
          }
        },
        "layout_constraints": {
          "type": "object"
        },
        "must_preserve": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "forbidden_changes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "worker": {
          "type": "object",
          "required": [
            "reasoning_level",
            "job_file"
          ],
          "properties": {
            "reasoning_level": {
              "enum": [
                "medium",
                "high"
              ]
            },
            "job_file": {
              "type": "string",
              "pattern": "^05_production/prompts/slide_\\d{2,}\\.json$"
            }
          },
          "additionalProperties": false
        },
        "qa_requirements": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "input_image": {
      "type": "object",
      "required": [
        "path",
        "role",
        "fidelity_rule",
        "required"
      ],
      "properties": {
        "asset_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "fidelity_rule": {
          "$ref": "#/$defs/fidelity_rule"
        },
        "required": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "coverage": {
      "type": "object",
      "required": [
        "requirement",
        "source",
        "covered_by"
      ],
      "properties": {
        "requirement": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "covered_by": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "fidelity_rule": {
      "enum": [
        "must use exact supplied image; no redraw or lookalike",
        "may crop/fit/color-balance only; no content changes",
        "preserve data, labels, axes, colors; do not redraw",
        "style reference only",
        "style reference only; do not copy client content",
        "preserve layout system and spacing"
      ]
    }
  },
  "additionalProperties": false
}
