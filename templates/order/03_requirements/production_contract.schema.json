{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PPT Production Contract",
  "type": "object",
  "required": [
    "deck",
    "method",
    "style_kit",
    "asset_registry",
    "slides",
    "approval"
  ],
  "properties": {
    "deck": {
      "type": "object",
      "required": [
        "deck_title",
        "page_count",
        "aspect_ratio",
        "deliverables",
        "language"
      ],
      "properties": {
        "deck_title": {
          "type": "string",
          "minLength": 1
        },
        "page_count": {
          "type": "integer",
          "minimum": 1
        },
        "aspect_ratio": {
          "enum": [
            "16:9",
            "4:3",
            "custom"
          ]
        },
        "deliverables": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "pptx",
              "pdf"
            ]
          },
          "uniqueItems": true
        },
        "language": {
          "type": "string",
          "minLength": 2
        }
      },
      "additionalProperties": false
    },
    "method": {
      "type": "object",
      "required": [
        "production_mode",
        "subagents_required",
        "default_reasoning_level",
        "same_backend_as_sample"
      ],
      "properties": {
        "production_mode": {
          "const": "image_model_full_slide"
        },
        "subagents_required": {
          "const": true
        },
        "default_reasoning_level": {
          "enum": [
            "medium",
            "high"
          ]
        },
        "same_backend_as_sample": {
          "type": "boolean"
        },
        "forbidden_methods": {
          "type": "array",
          "items": {
            "enum": [
              "html_css_render",
              "svg_render",
              "pillow_slide",
              "manual_overlay",
              "python_pptx_native_layout"
            ]
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "style_kit": {
      "type": "object",
      "required": [
        "required",
        "path",
        "source_type"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "path": {
          "const": "04_sample/style_kit/style_kit.json"
        },
        "source_type": {
          "enum": [
            "approved_sample",
            "customer_template",
            "source_deck",
            "approved_style_brief"
          ]
        }
      },
      "additionalProperties": false
    },
    "asset_registry": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/asset"
      }
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/slide"
      }
    },
    "coverage_matrix": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/coverage"
      }
    },
    "approval": {
      "type": "object",
      "required": [
        "approval_id"
      ],
      "properties": {
        "approval_id": {
          "type": "string",
          "minLength": 1
        },
        "approved_by": {
          "type": "string"
        },
        "approved_at": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "asset": {
      "type": "object",
      "required": [
        "asset_id",
        "asset_role",
        "source_path",
        "fidelity_rule",
        "if_missing"
      ],
      "properties": {
        "asset_id": {
          "type": "string",
          "minLength": 1
        },
        "asset_role": {
          "enum": [
            "strict_client_asset",
            "style_reference",
            "template_reference",
            "page_state_reference",
            "decorative_asset"
          ]
        },
        "source_path": {
          "type": "string",
          "minLength": 1
        },
        "source_message_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "sha256": {
          "type": [
            "string",
            "null"
          ]
        },
        "allowed_use": {
          "type": [
            "string",
            "null"
          ]
        },
        "fidelity_rule": {
          "type": "string",
          "minLength": 1
        },
        "if_missing": {
          "enum": [
            "block",
            "omit_if_optional"
          ]
        }
      },
      "additionalProperties": false
    },
    "slide": {
      "type": "object",
      "required": [
        "slide_no",
        "page_type",
        "title",
        "exact_content_source",
        "required_asset_ids",
        "job_path"
      ],
      "properties": {
        "slide_no": {
          "type": "integer",
          "minimum": 1
        },
        "page_type": {
          "enum": [
            "cover",
            "section",
            "content",
            "data",
            "image_heavy",
            "timeline",
            "process",
            "old_ppt_redesign",
            "closing",
            "custom"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "exact_content_source": {
          "type": "string",
          "minLength": 1
        },
        "required_asset_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "job_path": {
          "type": "string",
          "pattern": "^05_production/slide_jobs/slide_\\d{2,}/job\\.json$"
        }
      },
      "additionalProperties": false
    },
    "coverage": {
      "type": "object",
      "required": [
        "requirement",
        "source",
        "covered_by"
      ],
      "properties": {
        "requirement": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "covered_by": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
