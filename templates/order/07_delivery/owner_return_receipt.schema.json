{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Verified Owner Codex Return Receipt",
  "type": "object",
  "required": [
    "receipt_id",
    "order_id",
    "target",
    "manifest_path",
    "manifest_sha256",
    "files",
    "verified_at"
  ],
  "properties": {
    "receipt_id": {"type": "string", "minLength": 1},
    "order_id": {"type": "string", "minLength": 1},
    "target": {"const": "owner_codex"},
    "manifest_path": {"const": "07_delivery/owner_return_manifest.json"},
    "manifest_sha256": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "sha256", "type"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
          "type": {"enum": ["pptx", "pdf", "png", "zip", "other"]}
        },
        "additionalProperties": false
      }
    },
    "verified_at": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false
}
