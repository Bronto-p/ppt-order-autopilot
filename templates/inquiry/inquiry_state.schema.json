{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Inquiry State",
  "type": "object",
  "required": [
    "state_version",
    "inquiry_id",
    "source_type",
    "contact_id",
    "state",
    "ask_message_hash",
    "source_digest",
    "source_message_id",
    "source_prompt_sha256",
    "source_prompt_path",
    "source_attachment_hashes",
    "promotion_intent",
    "source_attachment_paths",
    "completed_reply_checks_minutes",
    "promoted_order_ids",
    "updated_at",
    "blocked_reason"
  ],
  "properties": {
    "state_version": {
      "const": 1
    },
    "inquiry_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_type": {
      "enum": [
        "wecom",
        "codex_attachment",
        null
      ]
    },
    "contact_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "state": {
      "enum": [
        "PREPARED",
        "ATTACHMENTS_STAGED",
        "SENT",
        "WAITING_REPLY",
        "REPLY_DETECTED",
        "CAPTURING",
        "PROMOTED",
        "NO_REPLY",
        "BLOCKED"
      ]
    },
    "ask_message_hash": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "source_digest": {
      "type": ["string", "null"],
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "source_message_id": {
      "type": ["string", "null"]
    },
    "source_prompt_sha256": {
      "type": ["string", "null"],
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "source_prompt_path": {
      "type": ["string", "null"]
    },
    "source_attachment_hashes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "sha256"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}
        },
        "additionalProperties": false
      }
    },
    "promotion_intent": {
      "type": ["object", "null"],
      "required": ["order_id", "title", "status"],
      "properties": {
        "order_id": {"type": "string"},
        "title": {"type": "string", "minLength": 1},
        "status": {"enum": ["pending", "order_created", "recorded"]}
      },
      "additionalProperties": false
    },
    "source_attachment_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "sent_message_ledger_id": {
      "type": ["string", "null"]
    },
    "sent_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "completed_reply_checks_minutes": {
      "type": "array",
      "items": {
        "type": "integer",
        "minimum": 0
      },
      "uniqueItems": true
    },
    "next_reply_check_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "reply_detected_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "promoted_order_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "updated_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "blocked_reason": {
      "type": ["string", "null"]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "source_type": {
            "const": "codex_attachment"
          }
        }
      },
      "then": {
        "required": ["source_digest", "source_message_id", "source_prompt_sha256", "source_prompt_path"],
        "properties": {
          "source_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
          "source_message_id": {"type": "string", "minLength": 1},
          "source_prompt_sha256": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
          "source_prompt_path": {"type": "string", "minLength": 1},
          "source_attachment_paths": {
            "minItems": 1
          },
          "source_attachment_hashes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "source_type": {
            "const": "wecom"
          }
        }
      },
      "then": {
        "properties": {
          "contact_id": {
            "type": "string",
            "minLength": 1
          },
          "ask_message_hash": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
